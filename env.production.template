# Trinity Oil Mills - Production environment template
# Copy this file to .env.production and replace the placeholder values.
# Do NOT commit .env.production to git (it contains secrets).

# ========== DATABASE (required) ==========
# MySQL/MariaDB connection. Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=mysql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:3306/trinityoil_oil_shop_db_new

# ========== AUTH (required for login/sessions) ==========
# Secret key for sessions and tokens. Generate a random string (e.g. 32+ chars).
# You can generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your-long-random-secret-key-here
NEXTAUTH_SECRET=your-long-random-secret-key-here

# Public URL of your app (used for login redirects, password reset links, etc.)
NEXTAUTH_URL=https://api.trinityoil.in
AUTH_URL=https://api.trinityoil.in

# ========== SERVER ==========
PORT=3001

# ========== EMAIL (for forgot-password, backup emails) ==========
# Gmail: use App Password (not your normal password). Enable 2FA, then create at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_EMAIL_FROM=your-email@gmail.com

# Alternative names (some code uses these):
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# ========== OPTIONAL ==========
# JWT_SECRET=optional-jwt-secret-if-you-use-it
